# Copiar a .env en la raíz del repo para docker compose
POSTGRES_USER=fuelops
POSTGRES_PASSWORD=fuelops_dev
POSTGRES_DB=fuelops
POSTGRES_PORT=5432

# --- Si ves: password authentication failed for user "fuelops" ---
# Postgres guarda la clave SOLO la primera vez que crea el volumen "postgres_data".
# Si ya existía el volumen con otra POSTGRES_PASSWORD, el API usa la nueva y Postgres la vieja.
# Solución A: en .env volvé a la misma contraseña con la que se creó el volumen.
# Solución B (BORRA LA BASE): docker compose down -v  y volvé a subir (pérdida de datos).
# Solución C: entrar a Postgres y: ALTER USER fuelops WITH PASSWORD 'la_misma_que_en_env';
# Evitá @ # : / ? en la contraseña o URL-encodeala en DATABASE_URL (mejor usar letras+números).

API_PORT=8000
# Si ves "Bind for :::3000 failed: port is already allocated", poné otro (ej. 3001)
FRONTEND_PORT=3000

# URL que usa el navegador para llamar al API (debe coincidir con el dominio público del backend).
# Local: http://localhost:8000
# Producción (ejemplo Irrigación Malargüe):
#   NEXT_PUBLIC_API_URL=https://api-tickets.irrigacionmalargue.net
NEXT_PUBLIC_API_URL=http://localhost:8000

GOOGLE_API_KEY=

# --- Proxy TLS (opcional) ---
# DNS A/AAAA: tickets.irrigacionmalargue.net y api-tickets.irrigacionmalargue.net → IP del servidor.
# Subí el stack con Caddy:
#   docker compose -f docker-compose.yml -f deploy/compose.caddy.yml up -d --build
# Convén cerrar 8000/3000 al mundo con firewall y dejar solo 80/443 si querés exponer solo HTTPS.
