# Copiar a .env en la raíz del repo para docker compose
POSTGRES_USER=fuelops
POSTGRES_PASSWORD=fuelops_dev
POSTGRES_DB=fuelops
POSTGRES_PORT=5432

# --- Si ves: password authentication failed for user "fuelops" o "fueluser" ---
# 1) USUARIO: POSTGRES_USER solo se aplica la PRIMERA vez que se crea el volumen postgres_data.
#    Si el volumen se creó con fuelops y en .env ponés fueluser, el API intenta fueluser pero
#    Postgres puede no tener ese rol → auth failed. Usá el mismo usuario que al crear el volumen,
#    o: docker compose exec db psql -U fuelops -d fuelops -c "ALTER USER fuelops RENAME TO fueluser;"
# 2) CONTRASEÑA: cambiar POSTGRES_PASSWORD en .env NO actualiza Postgres si el volumen ya existe.
#    Solución: ALTER USER ... WITH PASSWORD '...'; o docker compose down -v (borra datos).
# 3) API viejo: docker compose up -d --force-recreate api
# 4) Ver qué usa el API: docker compose exec api printenv POSTGRES_USER
#    Ver usuarios en Postgres: docker compose exec db psql -U fuelops -d fuelops -c '\du'
# El API arma DATABASE_URL en Python (encoding correcto si la clave tiene @ # etc.).
# En Docker el API usa POSTGRES_HOST=fuelops_db (no "db") para evitar choque con otros stacks en lyntrix_network.
# No uses $ en POSTGRES_PASSWORD sin escapar: en .env de compose, $VAR se interpreta como variable.

API_PORT=8000
# Si ves "Bind for :::3000 failed: port is already allocated", poné otro (ej. 3001)
FRONTEND_PORT=3000

# URL que usa el navegador para llamar al API (debe coincidir con el dominio público del backend).
# Si el sitio se sirve por HTTPS, esta URL tiene que ser https://... (si usás http:// el navegador bloquea "contenido mixto").
# Local: http://localhost:8000
# Producción (ejemplo Irrigación Malargüe):
#   NEXT_PUBLIC_API_URL=https://api-tickets.irrigacionmalargue.net
NEXT_PUBLIC_API_URL=http://localhost:8000

# Orígenes CORS permitidos (coma, sin espacios extra). Vacío = cualquier origen (sin credenciales CORS).
# En producción conviene listar solo el dominio del frontend:
#   CORS_ORIGINS=https://tickets.irrigacionmalargue.net
CORS_ORIGINS=

GOOGLE_API_KEY=

# --- Proxy TLS (opcional) ---
# DNS A/AAAA: tickets.irrigacionmalargue.net y api-tickets.irrigacionmalargue.net → IP del servidor.
# Subí el stack con Caddy:
#   docker compose -f docker-compose.yml -f deploy/compose.caddy.yml up -d --build
# Convén cerrar 8000/3000 al mundo con firewall y dejar solo 80/443 si querés exponer solo HTTPS.
